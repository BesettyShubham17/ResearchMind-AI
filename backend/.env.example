# ResearchMind AI – Environment Variables
# Copy this to .env and fill in your real API keys

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_very_long_random_secret_key_in_production

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@db:5432/researchmind

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ── Tavily Web Search ─────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-your-tavily-key-here

# ── Pinecone Vector DB ────────────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=researchmind
